# Copy to .env for local development only.
# Do not commit real credentials or API keys.

# LLM configuration
ARGUS_OPENAI_API_KEY=
ARGUS_MODEL_PROVIDER=openai
ARGUS_MODEL_NAME=gpt-4o-mini
ARGUS_MODEL_TEMPERATURE=0.0
ARGUS_MODEL_MAX_TOKENS=1200

# Browser configuration
ARGUS_HEADLESS=true
ARGUS_DEFAULT_TIMEOUT_SECONDS=20
ARGUS_NAVIGATION_TIMEOUT_SECONDS=45
ARGUS_SESSION_STATE_PATH=.argus/session_state.json
ARGUS_SCREENSHOT_DIR=screenshots

# Agent limits and safety
ARGUS_MAX_AGENT_STEPS=12
ARGUS_ALLOWED_DOMAINS=amazon.com,www.amazon.com
ARGUS_BLOCKED_DOMAINS=paypal.com,bank.example.com
ARGUS_LOG_LEVEL=INFO

# Optional login credentials (development convenience only)
# Prefer storing credentials in OS keyring.
ARGUS_AMAZON_USERNAME=
ARGUS_AMAZON_PASSWORD=
